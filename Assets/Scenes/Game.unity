--- !u!114 &1603153775
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1603153772}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9541d86e2fd84c1d9990edf0852d74ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshPro
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u042D\u0442\u0430 \u0438\u0433\u0440\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0435\u043A\u043E\u043C\u043C\u0435\u0440\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0430\u043D\u0430\u0442\u0441\u043A\u0438\u043C \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u043C,
    \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u043C \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437 \u043B\u044E\u0431\u0432\u0438 \u043A \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439
    Hollow Knight.\n\n\u0414\u0430\u043D\u043D\u044B\u0439 \u043F\u0440\u043E\u0435\u043A\u0442
    \u041D\u0415 \u0421\u0412\u042F\u0417\u0410\u041D, \u043D\u0435 \u043E\u0434\u043E\u0431\u0440\u0435\u043D
    \u0438 \u043D\u0435 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0441\u0442\u0443\u0434\u0438\u0435\u0439 Team Cherry.\n\n\u0412\u0441\u0435
    \u043F\u0440\u0430\u0432\u0430 \u043D\u0430 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439,
    \u043B\u043E\u043A\u0430\u0446\u0438\u0438, \u0441\u044E\u0436\u0435\u0442\u043D\u044B\u0435
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B, \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0430\u0441\u0441\u0435\u0442\u044B
    \u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u0443\u044E \u043C\u0430\u0440\u043A\u0443
    Hollow Knight, \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u0442
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    Team Cherry.\n\n\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0438
    \u044D\u0442\u043E\u0433\u043E \u0444\u0430\u043D\u0430\u0442\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0435\u043A\u0442\u0430 \u043D\u0435 \u043F\u0440\u0435\u0442\u0435\u043D\u0434\u0443\u044E\u0442
    \u043D\u0430 \u0432\u043B\u0430\u0434\u0435\u043D\u0438\u0435 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430\u043C\u0438. \u0412\u0441\u0435
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B
    \u0432 \u044D\u0442\u043E\u0439 \u0438\u0433\u0440\u0435 \u0441\u043E\u0437\u0434\u0430\u043D\u044B
    \u043A\u0430\u043A \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u044F
    \u0434\u043B\u044F \u0444\u0430\u043D\u0430\u0442\u043E\u0432.\n\n\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0442\u0435 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u043E\u0432,
    \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u0442\u0430\u044F \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0433\u0440\u044B \u0441\u0435\u0440\u0438\u0438 Hollow Knight."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 99d7a9c16fbbf3848bc0a5f941428aab, type: 2}
